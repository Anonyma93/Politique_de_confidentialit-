rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================
    // HELPER FUNCTIONS
    // ========================================

    // Vérifier si l'utilisateur est authentifié
    function isAuthenticated() {
      return request.auth != null;
    }

    // Vérifier si l'utilisateur est le propriétaire
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Vérifier si les données sont valides
    function isValidString(value, minLen, maxLen) {
      return value is string
        && value.size() >= minLen
        && value.size() <= maxLen;
    }

    // Vérifier si c'est un timestamp valide
    function isValidTimestamp(value) {
      return value is string && value.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}T.*');
    }

    // Rate limiting : max 1 post toutes les 30 secondes
    function canCreatePost() {
      return !exists(/databases/$(database)/documents/users/$(request.auth.uid)/lastPost)
        || get(/databases/$(database)/documents/users/$(request.auth.uid)/lastPost).data.timestamp < request.time - duration.value(30, 's');
    }

    // ========================================
    // USERS COLLECTION
    // ========================================
    match /users/{userId} {
      // Tout le monde peut lire les profils publics
      allow read: if isAuthenticated();

      // Créer son propre profil uniquement
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasAll(['displayName', 'email', 'createdAt'])
        && isValidString(request.resource.data.displayName, 1, 100)
        && isValidString(request.resource.data.email, 3, 254)
        && request.resource.data.createdAt is string;

      // Mettre à jour son propre profil
      allow update: if isOwner(userId)
        && (
          // Mise à jour normale des champs du profil (SANS les champs sensibles)
          (!request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['isPremium', 'premiumExpiresAt', 'postsCount', 'likesCount',
                     'likesGiven', 'userScore', 'engagementRate', 'createdAt', 'email', 'grade'])
          // Validation des champs modifiables
          && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['displayName'])
              || isValidString(request.resource.data.displayName, 1, 100))
          && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['firstName'])
              || isValidString(request.resource.data.firstName, 1, 50))
          && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['lastName'])
              || isValidString(request.resource.data.lastName, 1, 50))
          && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['photoURL'])
              || request.resource.data.photoURL is string))

          // OU incrémentation du compteur de posts (seulement +1)
          || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['postsCount', 'updatedAt'])
              && request.resource.data.postsCount == resource.data.postsCount + 1)

          // OU incrémentation du compteur de likes donnés par soi-même (seulement +1 ou -1)
          || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesGiven', 'updatedAt'])
              && (request.resource.data.likesGiven == resource.data.likesGiven + 1
                  || request.resource.data.likesGiven == resource.data.likesGiven - 1))

          // OU mise à jour du score et du grade (avec engagementRate optionnel)
          || (request.resource.data.diff(resource.data).affectedKeys().hasAny(['userScore', 'grade'])
              && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['userScore', 'engagementRate', 'grade', 'updatedAt']))

          // OU synchronisation du statut premium (après achat RevenueCat validé)
          || (request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['isPremium', 'premiumExpiresAt', 'lastSyncDate']))
        )
        // OU n'importe quel utilisateur authentifié peut modifier le compteur de likes reçus d'un autre utilisateur
        || (isAuthenticated()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'updatedAt'])
            && (request.resource.data.likesCount == resource.data.likesCount + 1
                || request.resource.data.likesCount == resource.data.likesCount - 1
                || request.resource.data.likesCount == 0))
        // OU n'importe quel utilisateur authentifié peut mettre à jour le score/grade d'un autre utilisateur
        || (isAuthenticated()
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['userScore', 'engagementRate', 'grade', 'updatedAt']));

      // Personne ne peut supprimer (utiliser Cloud Function ou Auth)
      allow delete: if false;

      // Document pour le rate limiting des posts
      match /lastPost {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    // ========================================
    // POSTS COLLECTION
    // ========================================
    match /posts/{postId} {
      // Tout le monde peut lire les posts (feed public)
      allow read: if true;

      // Créer un post si authentifié et propriétaire
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && isValidString(request.resource.data.line, 1, 50)
        && isValidString(request.resource.data.station, 1, 100)
        && isValidString(request.resource.data.comment, 1, 500)
        && request.resource.data.severity in ['sans', 'minime', 'perturbe', 'tres_perturbe', 'interrompu']
        && request.resource.data.type in ['incident', 'information']
        && isValidTimestamp(request.resource.data.createdAt)
        && request.resource.data.likesCount == 0
        && request.resource.data.commentsCount == 0
        && request.resource.data.likedBy.size() == 0
        // Validation optionnelle de la durée estimée
        && (!request.resource.data.keys().hasAny(['estimatedDuration'])
            || request.resource.data.estimatedDuration == null
            || request.resource.data.estimatedDuration in ['15min', '30min', '1h', '2h', 'half_day', 'full_day', 'unknown']);

      // Mettre à jour un post pour les likes/confirmations/commentaires
      allow update: if isAuthenticated()
        // Interdire la modification des champs principaux
        && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['userId', 'line', 'station', 'comment', 'severity', 'type', 'createdAt', 'direction', 'incident', 'destination', 'estimatedDuration'])
        // Autoriser uniquement les likes, confirmations et compteur de commentaires
        && (
          // Ajout d'un like
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'likesCount'])
            && request.resource.data.likedBy.hasAll(resource.data.likedBy)
            && request.resource.data.likedBy.size() == resource.data.likedBy.size() + 1
            && request.resource.data.likedBy.hasAll([request.auth.uid])
            && request.resource.data.likesCount == resource.data.likesCount + 1)
          // Retrait d'un like
          || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'likesCount'])
            && resource.data.likedBy.hasAll(request.resource.data.likedBy)
            && request.resource.data.likedBy.size() == resource.data.likedBy.size() - 1
            && !request.resource.data.likedBy.hasAll([request.auth.uid])
            && request.resource.data.likesCount == resource.data.likesCount - 1)
          // Incrémentation du compteur de commentaires (+1 ou -1)
          || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentsCount'])
            && (request.resource.data.commentsCount == resource.data.commentsCount + 1
                || request.resource.data.commentsCount == resource.data.commentsCount - 1))
        );

      // Supprimer son propre post uniquement
      allow delete: if isOwner(resource.data.userId);
    }

    // ========================================
    // COMMENTS COLLECTION
    // ========================================
    match /comments/{commentId} {
      // Tout le monde peut lire les commentaires
      allow read: if true;

      // Créer un commentaire si authentifié
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && isValidString(request.resource.data.text, 1, 500)
        && isValidString(request.resource.data.postId, 1, 200)
        && isValidTimestamp(request.resource.data.createdAt)
        && exists(/databases/$(database)/documents/posts/$(request.resource.data.postId));

      // Pas de mise à jour des commentaires (immutables)
      allow update: if false;

      // Supprimer son propre commentaire
      allow delete: if isOwner(resource.data.userId);
    }

    // ========================================
    // NOTIFICATIONS COLLECTION
    // ========================================
    match /notifications/{notificationId} {
      // Lire ses propres notifications
      allow read: if isAuthenticated()
        && resource.data.recipientId == request.auth.uid;

      // Créer une notification (automatique depuis l'app)
      allow create: if isAuthenticated()
        && request.resource.data.recipientId is string
        && request.resource.data.type in ['like', 'comment', 'post_mention', 'report']
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.read == false;

      // Marquer comme lue (seulement ses propres notifications)
      allow update: if isAuthenticated()
        && resource.data.recipientId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt'])
        && request.resource.data.read == true;

      // Pas de suppression
      allow delete: if false;
    }

    // ========================================
    // REPORTS COLLECTION
    // ========================================
    match /reports/{reportId} {
      // Lire ses propres signalements uniquement
      allow read: if isAuthenticated()
        && resource.data.reporterId == request.auth.uid;

      // Créer un signalement si authentifié
      allow create: if isAuthenticated()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.contentType in ['post', 'comment']
        && request.resource.data.reason in ['spam', 'inappropriate', 'dangerous', 'misinformation']
        && isValidString(request.resource.data.contentId, 1, 200)
        && isValidString(request.resource.data.postId, 1, 200);

      // Pas de mise à jour ni suppression
      allow update, delete: if false;
    }

    // ========================================
    // DENY ALL OTHER COLLECTIONS
    // ========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
